# AnthorOS ISO build — package USE flags

# installkernel: dracut for initramfs, grub for bootloader — no UKI/systemd paths
sys-kernel/installkernel grub dracut -ugrd -ukify -generic-uki
sys-kernel/gentoo-kernel-bin -generic-uki

# dracut without systemd — required for musl+openrc
sys-apps/dracut -systemd

# grub: BIOS + UEFI 64-bit
sys-boot/grub grub_platforms_efi-64 grub_platforms_pc

# util-linux: python bindings required by catalyst
sys-apps/util-linux python
